{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "read": {
      "*": "allow",
      ".env": "deny",
      ".env.*": "deny",
      "*.env": "deny",
      "*.env.*": "deny"
    },
    "edit": {
      "*": "deny",
      ".opencode/**": "allow",
      "opencode.json": "allow",
      ".gitignore": "allow",
      "app/admin/**": "allow",
      "app/api/admin/**": "allow",
      "lib/admin/**": "allow",
      "lib/supabase/**": "allow",
      "lib/filaments/drafts/**": "allow",
      "lib/filaments/imports/**": "allow",
      "lib/filaments/catalog/**": "allow",
      "lib/filaments/parameters/**": "allow",
      "lib/filaments/colors/**": "allow",
      "lib/storage/**": "allow"
    },
    "bash": {
      "*": "deny",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git branch*": "allow"
    },
    "external_directory": {
      "*": "deny"
    },
    "doom_loop": "ask"
  }
}
